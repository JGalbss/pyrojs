{
  "name": "@jgalbsss/pyrojs",
  "version": "0.1.0",
  "description": "A fireworks engine for the web — like react-confetti, but fireworks. 68 firework types, image/SVG/text fireworkify, a one-line React overlay, and an Effect-TS choreography DSL. Tiny, fast, and tree-shakeable.",
  "type": "module",
  "license": "MIT",
  "author": "JGalbss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JGalbss/fireworks.git"
  },
  "homepage": "https://github.com/JGalbss/fireworks#readme",
  "bugs": {
    "url": "https://github.com/JGalbss/fireworks/issues"
  },
  "keywords": [
    "fireworks",
    "particles",
    "particle-system",
    "canvas",
    "confetti",
    "react-confetti",
    "animation",
    "celebration",
    "effect-ts",
    "react"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./react": {
      "import": { "types": "./dist/react.d.ts", "default": "./dist/react.js" },
      "require": { "types": "./dist/react.d.cts", "default": "./dist/react.cjs" }
    },
    "./show": {
      "import": { "types": "./dist/show.d.ts", "default": "./dist/show.js" },
      "require": { "types": "./dist/show.d.cts", "default": "./dist/show.cjs" }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "effect": ">=3.10.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "effect": "^3.21.0",
    "happy-dom": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
